NODE_ENV="development"
PORT="4000"
API_PREFIX="/api/v1"
LOG_LEVEL="info"
DEFAULT_USER_ID="demo-user"
DATABASE_URL="file:./dev.db"

# Comma-separated list of exact frontend origins (scheme + host + optional port).
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173"
# Production example: CORS_ALLOWED_ORIGINS="https://lead-magic-studio.vercel.app"

# Comma-separated list of allowed frontend domain suffixes for preview/prod environments.
# Example: vercel.app,lead-magic-studio.com
CORS_ALLOWED_ORIGIN_SUFFIXES=""
